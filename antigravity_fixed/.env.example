# App
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/antigravity
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/antigravity

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-...

# AWS / Cloudflare R2
S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
S3_BUCKET=antigravity-uploads
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=auto

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=team@antigravity.app

# OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
